# Joinzer environment variables
# Copy to .env.local and fill in. NEVER commit .env.local — it holds secrets.
# NEXT_PUBLIC_* values are exposed to the browser; everything else is server-only.

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL + anon key are safe on the frontend (RLS enforces access).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key bypasses RLS — server-side ONLY, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App URL ─────────────────────────────────────────────────────────────────
# Canonical public URL. Used for emails, Stripe redirects, magic links, ICS/QR,
# and SEO metadata. Pick www OR apex and use it consistently. No trailing slash.
# Falls back to https://joinzer.com when unset (see lib/utils/site-url.ts).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Stripe ──────────────────────────────────────────────────────────────────
# Secret key + webhook signing secret are server-side ONLY.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# ── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key

# ── Cron (Vercel scheduled functions) ────────────────────────────────────────
# Shared secret that protects /api/cron/* routes. Set the same value in Vercel.
CRON_SECRET=your-random-cron-secret

# ── Google Maps (one-off geocoding script only) ──────────────────────────────
# Required by scripts/geocode-locations.mjs; not used by the app at runtime.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
